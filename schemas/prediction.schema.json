{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldcupbench/schemas/prediction.schema.json",
  "title": "WorldCupBench single-match prediction",
  "type": "object",
  "required": [
    "fixture_id",
    "model_id",
    "setting",
    "submitted_at",
    "win_probs",
    "score_dist",
    "most_likely_score",
    "reasoning"
  ],
  "additionalProperties": false,
  "properties": {
    "fixture_id":    { "type": "string" },
    "model_id":      { "type": "string" },
    "setting":       { "enum": ["S0","S1","S2a","S2b","S3a","S3b"] },
    "submitted_at":  { "type": "string", "format": "date-time" },

    "win_probs": {
      "type": "object",
      "required": ["home","draw","away"],
      "additionalProperties": false,
      "properties": {
        "home": { "type":"number", "minimum":0, "maximum":1 },
        "draw": { "type":"number", "minimum":0, "maximum":1 },
        "away": { "type":"number", "minimum":0, "maximum":1 }
      }
    },

    "score_dist": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["score","p"],
        "additionalProperties": false,
        "properties": {
          "score": { "type":"string", "pattern":"^[0-9]+-[0-9]+$" },
          "p":     { "type":"number", "minimum":0, "maximum":1 }
        }
      }
    },
    "most_likely_score": { "type":"string", "pattern":"^[0-9]+-[0-9]+$" },
    "expected_goal_diff": { "type":"number" },
    "advance_prob": { "type":"number", "minimum":0, "maximum":1 },

    "lineups": {
      "type":"object",
      "properties": {
        "home": { "$ref":"#/$defs/lineup" },
        "away": { "$ref":"#/$defs/lineup" }
      }
    },
    "formations": {
      "type":"object",
      "properties": {
        "home": { "type":"string", "pattern":"^[0-9]+(-[0-9]+)+$" },
        "away": { "type":"string", "pattern":"^[0-9]+(-[0-9]+)+$" }
      }
    },

    "scorers": {
      "type":"array",
      "items": {
        "type":"object",
        "required":["player","team","p"],
        "properties": {
          "player":        { "type":"string" },
          "team":          { "enum":["home","away"] },
          "minute_range":  { "type":"array", "items":{"type":"number"}, "minItems":2, "maxItems":2 },
          "p":             { "type":"number", "minimum":0, "maximum":1 }
        }
      }
    },
    "assisters": {
      "type":"array",
      "items": { "type":"object", "required":["player","team","p"] }
    },
    "substitutions": {
      "type":"array",
      "items": {
        "type":"object",
        "required":["team","off","on","minute"],
        "properties": {
          "team":   { "enum":["home","away"] },
          "off":    { "type":"string" },
          "on":     { "type":"string" },
          "minute": { "type":"number", "minimum":0, "maximum":130 }
        }
      }
    },
    "cards": {
      "type":"array",
      "items": {
        "type":"object",
        "required":["player","team","color","minute"],
        "properties": {
          "player":{ "type":"string" },
          "team":  { "enum":["home","away"] },
          "color": { "enum":["yellow","red","second_yellow"] },
          "minute":{ "type":"number" }
        }
      }
    },
    "penalties":   { "type":"array" },
    "own_goals":   { "type":"array" },
    "motm_probs":  { "type":"array" },

    "stats": {
      "type":"object",
      "description":"Per-side match stats. Keys are stat names; values have {home, away} numbers.",
      "additionalProperties": {
        "type":"object",
        "properties": {
          "home":{"type":"number"},
          "away":{"type":"number"}
        }
      }
    },

    "reasoning": { "type":"string", "minLength": 20 },
    "thinking":  { "type":"string" },
    "sources": {
      "type":"array",
      "items": {
        "type":"object",
        "required":["url","accessed_at"],
        "properties":{
          "url":          { "type":"string", "format":"uri" },
          "accessed_at":  { "type":"string", "format":"date-time" },
          "published_at": { "type":"string", "format":"date-time" },
          "title":        { "type":"string" }
        }
      }
    }
  },

  "$defs": {
    "lineup": {
      "type":"object",
      "required":["starting","bench"],
      "properties": {
        "starting": { "type":"array", "minItems":11, "maxItems":11,
                      "items":{"$ref":"#/$defs/player"} },
        "bench":    { "type":"array", "items":{"$ref":"#/$defs/player"} }
      }
    },
    "player": {
      "type":"object",
      "required":["name","position"],
      "properties":{
        "name":     { "type":"string" },
        "position": { "enum":["GK","DF","MF","FW"] },
        "shirt":    { "type":"integer" }
      }
    }
  }
}
